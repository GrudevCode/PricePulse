# ── Database (Supabase) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-1-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=no-verify

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
# Get from upstash.com → Create Database → .env tab (use rediss:// for TLS)
REDIS_URL=rediss://default:[token]@[host].upstash.io:6379

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...
AI_PROVIDER=openai

# ── Security ──────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=32characterrandomstringgoeshere!
# JWT kept only for legacy migration; safe to remove once all users are on Clerk
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here

# ── Clerk ─────────────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_...
# Webhook secret — from Clerk dashboard → Webhooks → your endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_...

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get from resend.com → API Keys. Also add + verify your sending domain.
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com
SQUARE_APP_ID=
SQUARE_APP_SECRET=
TOAST_CLIENT_ID=
TOAST_CLIENT_SECRET=
LIGHTSPEED_CLIENT_ID=
LIGHTSPEED_CLIENT_SECRET=
PREDICTHQ_API_KEY=
GOOGLE_PLACES_API_KEY=
OPEN_METEO_BASE_URL=https://api.open-meteo.com
FRONTEND_URL=http://localhost:5173
# Optional: frontend origin for QR only (scheme + host + port). Example: http://192.168.1.5:5173 — do NOT add /menu/... (the API appends /menu/:slug). Localhost won't work when scanning from a phone.
QR_MENU_PUBLIC_URL=
PORT=3001
NODE_ENV=development
